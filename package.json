{
  "name": "MAUDConnect",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "assets": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res/",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "postinstall": "patch-package",
    "android:clean": "node scripts/prebuild.js && cd android && ./gradlew clean",
    "android:fresh": "yarn android:clean && yarn android",
    "ios-build": "react-native bundle --entry-file index.js --platform ios --dev false --bundle-output ios/main.jsbundle --assets-dest ios/assets",
    "debug-apk": "cd android && gradlew assembleDebug",
    "release-apk": "cd android && gradlew assembleRelease",
    "release-aab": "cd android && gradlew bundleRelease"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/geolocation": "3.4.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native/new-app-screen": "0.85.3",
    "@react-navigation/bottom-tabs": "7.8.12",
    "@react-navigation/native": "7.1.25",
    "@react-navigation/stack": "7.6.12",
    "@reduxjs/toolkit": "2.11.2",
    "axios": "1.13.2",
    "openai": "4.104.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-background-timer": "2.4.1",
    "react-native-chart-kit": "6.12.0",
    "react-native-encrypted-storage": "4.0.3",
    "react-native-gesture-handler": "2.29.1",
    "react-native-maps": "1.14.0",
    "react-native-permissions": "5.4.0",
    "react-native-reanimated": "4.4.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "4.18.0",
    "react-native-sensors": "7.3.6",
    "react-native-svg": "15.15.5",
    "react-native-vector-icons": "10.2.0",
    "react-native-worklets": "0.9.1",
    "react-redux": "9.2.0",
    "redux-persist": "6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "prop-types": "^15.8.1",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
