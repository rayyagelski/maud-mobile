# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# react-native-permissions: patches RNPermissions.podspec to include only
# the permission handlers the app actually uses
require_relative '../node_modules/react-native-permissions/scripts/setup'

platform :ios, min_ios_version_supported
prepare_react_native_project!

setup_permissions([
  'LocationWhenInUse',
  'LocationAlways',
  'Motion',
])

# Static frameworks allow Swift to import React Native modules (React_RCTAppDelegate etc.)
use_frameworks! :linkage => :static

target 'MAUDConnect' do
  config = use_native_modules!

  # Explicit Google Maps pod — use_native_modules picks up react-native-maps
  # (Apple Maps), but the Google Maps variant is a separate podspec
  pod 'react-native-google-maps', :path => '../node_modules/react-native-maps'

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # Static frameworks require a consistent deployment target across all pods
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.4'
        # Xcode 16+ sandboxes user script phases by default, which breaks
        # CocoaPods embed/copy scripts that use rsync across framework boundaries.
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        # use_frameworks! :static makes every pod a module; react-native-maps and
        # other ObjC pods import React-Core headers that are not modular — allow it.
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      end
    end
  end
end
